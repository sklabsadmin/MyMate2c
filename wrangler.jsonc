{
  "$schema": "node_modules/wrangler/config-schema.json",
  // mymate-v2 is the new active-development worker. mymate2c is now a
  // frozen checkpoint (same pattern as mymate-api for the 1.39 App Store
  // build) — nothing should deploy to it going forward.
  "name": "mymate2c",
  "main": "backend/src/worker.js",
  "compatibility_date": "2026-07-05",
  "workers_dev": true,
  "routes": [
    { "pattern": "chat.deeploveechoes.com", "custom_domain": true },
    { "pattern": "chat.deeplovepoems.com", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "build/web",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*",
      "/auth/*",
      "/admin/*"
    ]
  },
  "vars": {
    "REQUIRE_CHAT_LOGS": "false",
    // HMAC signing on /api/chat. Off pre-launch so the web build doesn't need
    // APP_SECRET baked in. Set to "true" (or remove this line) before real
    // users exist — it's what stops strangers spending our OpenAI credits.
    // When turning it back on, the client build must use the SAME APP_SECRET
    // as the worker's secret, or every request fails with "Invalid signature".
    "REQUIRE_SIGNATURE": "false",
    // Update this once the worker's real URL is confirmed (used for
    // Instagram/Google-auth redirects only; not load-bearing for chat/logging).
    "APP_ORIGIN": "https://mymate-v2.sklabs-admin.workers.dev",
    // Google Sign-In (Settings > Continue with Google). Client ID is not
    // secret; GOOGLE_CLIENT_SECRET is set via `wrangler secret put`.
    "GOOGLE_CLIENT_ID": "791029751937-vf4kbpfs1h1t6kmvb83eu9mquidj070g.apps.googleusercontent.com"
    // GOOGLE_REDIRECT_URI is deliberately NOT set. getGoogleRedirectUri() falls
    // back to `<origin of this request>/auth/google/callback`, so sign-in
    // completes on whichever domain the user actually started on instead of
    // bouncing everyone to workers.dev. Setting it again pins all three origins
    // back to one URL.
    //
    // Every origin that needs sign-in must be listed as an Authorized redirect
    // URI on the OAuth client in Google Cloud Console, or Google rejects the
    // request with redirect_uri_mismatch:
    //   https://mymate-v2.sklabs-admin.workers.dev/auth/google/callback
    //   https://chat.deeploveechoes.com/auth/google/callback
    //   https://chat.deeplovepoems.com/auth/google/callback
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "CHAT_LOGS_DB",
      "database_name": "mymate2_db",
      "database_id": "5ada4bd9-a4ad-4a75-8c0a-5f4d023f578f",
      "migrations_dir": "backend/migrations"
    }
  ]
}
