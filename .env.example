# Proxy Configuration
#
# mymate-api.sklabs-admin.workers.dev is the stable backend the currently
# shipped/approved App Store build (1.39) points at. Don't redeploy this
# repo's code onto it.
# mymate2c.sklabs-admin.workers.dev is a frozen checkpoint from the v2
# chat-logging work. Nothing deploys to it anymore — same "leave it alone"
# rule as mymate-api.
# mymate-v2.sklabs-admin.workers.dev is this repo's active development
# backend (GitHub auto-deploy on push to main) for the next app release.
WORKER_URL=https://mymate-v2.sklabs-admin.workers.dev
APP_SECRET=your_generated_secret_key_here

# RevenueCat Public SDK Keys (for configuring Purchases SDK on iOS/Android)
# Get these from your RevenueCat dashboard. Example: 'appl_1a2b3c4d5e6f7h'
REVENUECAT_IOS_KEY=your_revenuecat_ios_public_key_here
REVENUECAT_ANDROID_KEY=your_revenuecat_android_public_key_here
REVENUECAT_WEB_KEY=your_revenuecat_web_billing_key_here

# Optional Instagram auth for the Cloudflare proxy.
APP_ORIGIN=http://localhost:8787
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret
INSTAGRAM_REDIRECT_URI=https://your-api-worker.workers.dev/auth/instagram/callback
